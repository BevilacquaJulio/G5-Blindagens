# ─────────────────────────────────────────────────────────────────────
# .env RAIZ (Docker) — Atlas Stock
# Copie para `.env` e preencha. NUNCA comite o `.env` real.
# Este arquivo alimenta tanto a interpolacao do docker-compose (DOMAIN,
# TRAEFIK_*) quanto o runtime dos containers (via env_file).
# ─────────────────────────────────────────────────────────────────────

# ─── Dominio publico (Traefik) ───
# Frontend em https://${DOMAIN} ; API em https://api.${DOMAIN}
DOMAIN=g5.seudominio.com.br
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_CERT_RESOLVER=letsencrypt

# ─── Aplicacao ───
NODE_ENV=production
PORT=3000

# ─── Banco MySQL compartilhado ───
# MYSQL_HOST = nome do container MySQL na rede mysql_shared (NUNCA localhost).
# O banco `g5` e o usuario precisam existir ANTES do primeiro deploy
# (rode sql/create_database.sql manualmente e crie o usuario).
MYSQL_HOST=mysql_shared
MYSQL_PORT=3306
MYSQL_USER=g5_user
MYSQL_PASSWORD=troque_esta_senha
MYSQL_DATABASE=g5

# ─── JWT (segredos longos e DISTINTOS entre access e refresh) ───
JWT_ACCESS_SECRET=troque-por-um-segredo-forte-de-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=troque-por-outro-segredo-forte-distinto
JWT_REFRESH_EXPIRES_IN=7d

# ─── Seguranca ───
# CORS deve bater com a origem publica do frontend.
CORS_ORIGIN=https://g5.seudominio.com.br
THROTTLE_TTL=60
THROTTLE_LIMIT=120

# ─── Seed (obrigatorio apenas ao executar o seed inicial) ───
SEED_ADMIN_EMAIL=admin@atlas.com
SEED_ADMIN_PASSWORD="admin@123#"
SEED_FINANCEIRO_SENHA="admin@123#"
