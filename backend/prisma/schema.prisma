// Schema Prisma — ERP Atlas Stock
// Prisma 7 + driver adapter mariadb. O datasource NÃO tem `url`: a conexão
// vive em prisma.config.ts. O client é gerado em ./generated/prisma.
//
// O schema evolui por fase (migração incremental do sistema PHP legado):
//   Fase 1: autenticação + cadastros.
//   Fase 2: compras + despesas vinculadas.
//   Fase 3: projetos de blindagem.
//   Fase 4 (esta): financeiro completo + dashboard.

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

// ─────────────────────────────── Enums ───────────────────────────────

enum Cargo {
  ADMINISTRADOR
  GERENTE
  OPERADOR
}

enum ClienteTipo {
  PF
  PJ
}

enum ProdutoEscopo {
  GERAL
  PROJETO
}

enum MovimentacaoTipo {
  ENTRADA
  SAIDA
}

enum CompraStatus {
  A_PAGAR
  CONFIRMADA
  PAGO
  CANCELADA
}

enum DespesaStatus {
  A_PAGAR
  PAGO
  CANCELADA
}

enum ReceitaStatus {
  A_RECEBER
  RECEBIDO
}

enum ProjetoStatus {
  AGUARDANDO
  EM_ANDAMENTO
  CONCLUIDO
  CANCELADO
}

enum ProjetoConsumoTipo {
  PRODUTO
  SERVICO
}

// ───────────────────────────── Autenticação ──────────────────────────

model Usuario {
  id        Int      @id @default(autoincrement())
  nome      String   @db.VarChar(150)
  email     String   @unique @db.VarChar(180)
  senha     String   @map("senha") @db.VarChar(255) // hash bcrypt
  cargo     Cargo    @default(OPERADOR)
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  movimentacoes Movimentacao[]
  refreshTokens RefreshToken[]
  compras       Compra[]
  projetos      Projeto[]
  projetoHistorico ProjetoHistorico[]
  projetoConsumos  ProjetoConsumo[]

  @@map("usuarios")
}

model RefreshToken {
  id        Int       @id @default(autoincrement())
  usuarioId Int       @map("usuario_id")
  tokenHash String    @map("token_hash") @db.VarChar(255)
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId])
  @@map("refresh_tokens")
}

// ─────────────────────────────── Cadastros ───────────────────────────

model Categoria {
  id        Int      @id @default(autoincrement())
  nome      String   @unique @db.VarChar(120)
  descricao String?  @db.Text
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  produtos Produto[]

  @@map("categorias")
}

model Produto {
  id                Int           @id @default(autoincrement())
  codigo            String        @unique @db.VarChar(60)
  nome              String        @db.VarChar(200)
  descricao         String?       @db.Text
  categoriaId       Int?          @map("categoria_id")
  unidadeMedida     String        @map("unidade_medida") @db.VarChar(20)
  valorUnitario     Decimal       @default(0) @map("valor_unitario") @db.Decimal(12, 2)
  quantidadeEstoque Decimal       @default(0) @map("quantidade_estoque") @db.Decimal(12, 3)
  custoMedio        Decimal       @default(0) @map("custo_medio") @db.Decimal(12, 2)
  escopo            ProdutoEscopo @default(GERAL)
  projetoId         Int?          @map("projeto_id") // FK adicionada na fase de Projetos
  ativo             Boolean       @default(true)
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  categoria     Categoria?     @relation(fields: [categoriaId], references: [id], onDelete: SetNull)
  projeto       Projeto?       @relation(fields: [projetoId], references: [id], onDelete: SetNull)
  movimentacoes Movimentacao[]
  compraItens   CompraItem[]
  projetoConsumos ProjetoConsumo[]

  @@index([categoriaId])
  @@index([projetoId])
  @@index([ativo])
  @@map("produtos")
}

model Fornecedor {
  id              Int      @id @default(autoincrement())
  nomeRazaoSocial String   @map("nome_razao_social") @db.VarChar(200)
  cpfCnpj         String   @map("cpf_cnpj") @db.VarChar(20)
  telefone        String?  @db.VarChar(30)
  email           String?  @db.VarChar(180)
  ativo           Boolean  @default(true)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  compras  Compra[]
  despesas Despesa[]

  @@index([ativo])
  @@map("fornecedores")
}

model Cliente {
  id           Int         @id @default(autoincrement())
  tipo         ClienteTipo @default(PF)
  nomeCompleto String      @map("nome_completo") @db.VarChar(200)
  cpfCnpj      String      @map("cpf_cnpj") @db.VarChar(20)
  telefone     String?     @db.VarChar(30)
  email        String?     @db.VarChar(180)
  cep          String?     @db.VarChar(15)
  rua          String?     @db.VarChar(200)
  numero       String?     @db.VarChar(20)
  complemento  String?     @db.VarChar(120)
  bairro       String?     @db.VarChar(120)
  cidade       String?     @db.VarChar(120)
  estado       String?     @db.VarChar(2)
  observacoes  String?     @db.Text
  ativo        Boolean     @default(true)
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  veiculos Veiculo[]
  projetos Projeto[]
  receitas Receita[]

  @@index([ativo])
  @@map("clientes")
}

model Veiculo {
  id                   Int      @id @default(autoincrement())
  clienteId            Int      @map("cliente_id")
  placa                String   @db.VarChar(10)
  marca                String   @db.VarChar(80)
  modelo               String   @db.VarChar(120)
  ano                  String?  @db.VarChar(10)
  cor                  String?  @db.VarChar(40)
  observacoesTecnicas  String?  @map("observacoes_tecnicas") @db.Text
  ativo                Boolean  @default(true)
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  cliente Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  projetos Projeto[]

  @@index([clienteId])
  @@index([ativo])
  @@map("veiculos")
}

model Movimentacao {
  id               Int              @id @default(autoincrement())
  produtoId        Int              @map("produto_id")
  tipo             MovimentacaoTipo
  quantidade       Decimal          @db.Decimal(12, 3)
  custoUnitario    Decimal          @default(0) @map("custo_unitario") @db.Decimal(12, 2)
  valorTotal       Decimal          @default(0) @map("valor_total") @db.Decimal(12, 2)
  motivo           String?          @db.VarChar(200)
  projetoId        Int?             @map("projeto_id") // FK adicionada na fase de Projetos
  compraId         Int?             @map("compra_id")
  usuarioId        Int              @map("usuario_id")
  dataMovimentacao DateTime         @default(now()) @map("data_movimentacao")

  produto Produto @relation(fields: [produtoId], references: [id], onDelete: Cascade)
  usuario Usuario @relation(fields: [usuarioId], references: [id])
  compra  Compra? @relation(fields: [compraId], references: [id], onDelete: SetNull)
  projeto Projeto? @relation(fields: [projetoId], references: [id], onDelete: SetNull)

  @@index([produtoId])
  @@index([tipo])
  @@index([projetoId])
  @@index([compraId])
  @@map("movimentacoes")
}

// ─────────────────────────────── Compras ───────────────────────────

model Compra {
  id            Int          @id @default(autoincrement())
  fornecedorId  Int          @map("fornecedor_id")
  status        CompraStatus @default(A_PAGAR)
  dataCompra    DateTime     @default(now()) @map("data_compra")
  dataPagamento DateTime?    @map("data_pagamento")
  valorTotal    Decimal      @default(0) @map("valor_total") @db.Decimal(12, 2)
  observacoes   String?      @db.Text
  usuarioId     Int          @map("usuario_id")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  fornecedor    Fornecedor     @relation(fields: [fornecedorId], references: [id])
  usuario       Usuario        @relation(fields: [usuarioId], references: [id])
  itens         CompraItem[]
  despesa       Despesa?
  movimentacoes Movimentacao[]

  @@index([fornecedorId])
  @@index([status])
  @@index([dataCompra])
  @@map("compras")
}

model CompraItem {
  id            Int     @id @default(autoincrement())
  compraId      Int     @map("compra_id")
  produtoId     Int     @map("produto_id")
  quantidade    Decimal @db.Decimal(12, 3)
  valorUnitario Decimal @map("valor_unitario") @db.Decimal(12, 2)
  valorTotal    Decimal @map("valor_total") @db.Decimal(12, 2)

  compra  Compra  @relation(fields: [compraId], references: [id], onDelete: Cascade)
  produto Produto @relation(fields: [produtoId], references: [id])

  @@index([compraId])
  @@index([produtoId])
  @@map("compra_itens")
}

// Despesa vinculada a compra ou avulsa; módulo financeiro completo na Fase 4.
model Despesa {
  id                Int           @id @default(autoincrement())
  descricao         String        @db.VarChar(200)
  valor             Decimal       @db.Decimal(12, 2)
  status            DespesaStatus @default(A_PAGAR)
  dataVencimento    DateTime?     @map("data_vencimento")
  dataPagamento     DateTime?     @map("data_pagamento")
  fornecedorId      Int?          @map("fornecedor_id")
  categoriaDespesaId Int?         @map("categoria_despesa_id")
  compraId          Int?          @unique @map("compra_id")
  projetoId         Int?          @map("projeto_id")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  fornecedor       Fornecedor?      @relation(fields: [fornecedorId], references: [id], onDelete: SetNull)
  categoriaDespesa CategoriaDespesa? @relation(fields: [categoriaDespesaId], references: [id], onDelete: SetNull)
  compra           Compra?          @relation(fields: [compraId], references: [id], onDelete: Cascade)
  projeto          Projeto?         @relation(fields: [projetoId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([categoriaDespesaId])
  @@index([projetoId])
  @@map("despesas")
}

// ─────────────────────────────── Projetos ──────────────────────────

model Projeto {
  id            Int           @id @default(autoincrement())
  clienteId     Int           @map("cliente_id")
  veiculoId     Int           @map("veiculo_id")
  status        ProjetoStatus @default(AGUARDANDO)
  descricao     String?       @db.Text
  valorOrcado   Decimal       @default(0) @map("valor_orcado") @db.Decimal(12, 2)
  valorFinal    Decimal?      @map("valor_final") @db.Decimal(12, 2)
  dataInicio    DateTime?     @map("data_inicio")
  dataConclusao DateTime?     @map("data_conclusao")
  usuarioId     Int           @map("usuario_id")
  ativo         Boolean       @default(true)
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  cliente       Cliente                @relation(fields: [clienteId], references: [id])
  veiculo       Veiculo                @relation(fields: [veiculoId], references: [id])
  usuario       Usuario                @relation(fields: [usuarioId], references: [id])
  checklist     ProjetoChecklistItem[]
  historico     ProjetoHistorico[]
  consumos      ProjetoConsumo[]
  produtos      Produto[]
  movimentacoes Movimentacao[]
  receitas      Receita[]
  despesas      Despesa[]

  @@index([clienteId])
  @@index([veiculoId])
  @@index([status])
  @@index([ativo])
  @@map("projetos")
}

model ProjetoChecklistItem {
  id          Int       @id @default(autoincrement())
  projetoId   Int       @map("projeto_id")
  descricao   String    @db.VarChar(300)
  concluido   Boolean   @default(false)
  ordem       Int       @default(0)
  concluidoEm DateTime? @map("concluido_em")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  projeto Projeto @relation(fields: [projetoId], references: [id], onDelete: Cascade)

  @@index([projetoId])
  @@map("projeto_checklist_itens")
}

model ProjetoHistorico {
  id             Int            @id @default(autoincrement())
  projetoId      Int            @map("projeto_id")
  statusAnterior ProjetoStatus? @map("status_anterior")
  statusNovo     ProjetoStatus  @map("status_novo")
  observacao     String?        @db.Text
  usuarioId      Int            @map("usuario_id")
  createdAt      DateTime       @default(now()) @map("created_at")

  projeto Projeto @relation(fields: [projetoId], references: [id], onDelete: Cascade)
  usuario Usuario @relation(fields: [usuarioId], references: [id])

  @@index([projetoId])
  @@map("projeto_historico")
}

model ProjetoConsumo {
  id            Int                @id @default(autoincrement())
  projetoId     Int                @map("projeto_id")
  tipo          ProjetoConsumoTipo @default(PRODUTO)
  produtoId     Int?               @map("produto_id")
  descricao     String?            @db.VarChar(200)
  quantidade    Decimal            @db.Decimal(12, 3)
  valorUnitario Decimal            @map("valor_unitario") @db.Decimal(12, 2)
  valorTotal    Decimal            @map("valor_total") @db.Decimal(12, 2)
  usuarioId     Int                @map("usuario_id")
  createdAt     DateTime           @default(now()) @map("created_at")

  projeto Projeto  @relation(fields: [projetoId], references: [id], onDelete: Cascade)
  produto Produto? @relation(fields: [produtoId], references: [id], onDelete: SetNull)
  usuario Usuario  @relation(fields: [usuarioId], references: [id])

  @@index([projetoId])
  @@index([produtoId])
  @@map("projeto_consumos")
}

// ─────────────────────────────── Financeiro ────────────────────────

model CategoriaDespesa {
  id        Int      @id @default(autoincrement())
  nome      String   @unique @db.VarChar(120)
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  despesas Despesa[]

  @@map("categoria_despesa")
}

model Receita {
  id              Int           @id @default(autoincrement())
  descricao       String        @db.VarChar(200)
  valor           Decimal       @db.Decimal(12, 2)
  status          ReceitaStatus @default(A_RECEBER)
  dataVencimento  DateTime?     @map("data_vencimento")
  dataRecebimento DateTime?     @map("data_recebimento")
  clienteId       Int?          @map("cliente_id")
  projetoId       Int?          @map("projeto_id")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  cliente Cliente? @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  projeto Projeto? @relation(fields: [projetoId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([clienteId])
  @@index([projetoId])
  @@map("receitas")
}

/// Configuração singleton do sistema (senha financeiro, etc.).
model ConfigSistema {
  id                  Int      @id @default(1)
  financeiroSenhaHash String?  @map("financeiro_senha_hash") @db.VarChar(255)
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("config_sistema")
}
