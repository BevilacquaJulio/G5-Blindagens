# ─── Aplicação ───
NODE_ENV=development
PORT=3000

# ─── Banco de dados MySQL ───
# A URL de conexão é montada a partir destas variáveis (ver src/config/database-url.ts).
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=g5

# ─── JWT (use segredos longos e DISTINTOS entre access e refresh) ───
JWT_ACCESS_SECRET=troque-por-um-segredo-forte-de-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=troque-por-outro-segredo-forte-distinto
JWT_REFRESH_EXPIRES_IN=7d

# ─── Segurança ───
CORS_ORIGIN=http://localhost:5173
THROTTLE_TTL=60
THROTTLE_LIMIT=120

# ─── Seed (obrigatório apenas ao executar o seed inicial) ───
SEED_ADMIN_EMAIL=admin@g5.local
SEED_ADMIN_PASSWORD=troque-esta-senha-admin-com-12-chars
SEED_FINANCEIRO_SENHA=troque-esta-senha-financeiro-com-12-chars
